# Environment variables — copy this file to .env and fill in your values
# Never commit the real .env file to version control

# Required for --live mode only
POLY_PRIVATE_KEY=your_polygon_private_key_here
POLY_PROXY_WALLET=your_polymarket_proxy_wallet_address_here
POLY_SIGNATURE_TYPE=2
POLY_PUSD_TOKEN=0xC011a7E12a19f7B1f670d46F03B03f3342E82DFB
DASHBOARD_PASSWORD=your_dashboard_password_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional for redeem worker / relayer operations
RELAYER_API_KEY=your_relayer_api_key_here
RELAYER_API_KEY_ADDRESS=your_relayer_api_key_address_here
POLYGON_RPC_URL=https://polygon-rpc.example
POLYGON_RPC_URLS=https://polygon-bor.publicnode.com,https://polygon.drpc.org,https://rpc-mainnet.polygon.technology
